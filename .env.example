# OmniVoice TTS Server - Environment Configuration
# Copy this file to .env and fill in only the values you need.

# ---------------------------------------------------------------------------
# Hugging Face access (optional)
# ---------------------------------------------------------------------------
# Set this when downloading gated or rate-limited Hugging Face assets.
# Leave empty if your model is already local or publicly accessible.
# HF_TOKEN=hf_your_token_here

# ---------------------------------------------------------------------------
# Authentication (optional)
# ---------------------------------------------------------------------------
# Setting this in .env has no effect unless the OMNIVOICE_API_KEY line in
# compose.yaml is enabled.
# When enabled, authenticated HTTP routes require:
#   Authorization: Bearer <your-key>
# GET /health and the current WebSocket endpoints remain unauthenticated.
# OMNIVOICE_API_KEY=change-me-if-you-enable-auth
